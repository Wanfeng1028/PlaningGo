# ── 应用 ──
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── 前端 ──
VITE_API_BASE=http://127.0.0.1:3001

# ── PostgreSQL ──
DATABASE_URL=postgresql://planninggo:planninggo@localhost:5432/planninggo?schema=public

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT ──
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-production-32b
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-production-32b
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── 加密 ──
BCRYPT_ROUNDS=10

# ── 规划引擎: mock | llm | hybrid ──
PLANNING_MODE=mock
ENABLE_LLM_FALLBACK=false

# ── LLM ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TIMEOUT_MS=30000

# ── 外部服务 ──
AMAP_WEB_SERVICE_KEY=
QWEATHER_API_KEY=

# ── Load test ──
LOAD_TEST_BASE_URL=http://127.0.0.1:3001
